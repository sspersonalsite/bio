---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('musings');
  return posts.map(post => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const posts = await getCollection('musings');
const post = posts.find(p => p.id === slug);
if (!post) return Astro.redirect('/musings');

const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Scott Seidel`} page="musings">
  <div class="page-body">
    <div class="container">

      <header class="post-header">
        <a href="/musings" class="back-link">← Musings</a>
        <p class="post-header-meta" style="margin-top: 1.5rem;">{post.data.date}</p>
        <h1>{post.data.title}</h1>
      </header>

      {post.data.video && (
        <div class="post-hero-media">
          <video autoplay muted loop playsinline>
            <source src={post.data.video} type="video/mp4" />
          </video>
        </div>
      )}
      {post.data.image && !post.data.video && (
        <div class="post-hero-media">
          <img src={post.data.image} alt={post.data.title} />
        </div>
      )}

      <div class="post-body">
        <Content />
      </div>

      <div style="padding: 2rem 0 5rem; border-top: 1px solid var(--border);">
        <a href="/musings" class="back-link">← Back to Musings</a>
      </div>

    </div>
  </div>
</Layout>
