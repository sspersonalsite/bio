<script>
// Scroll-triggered reveals via IntersectionObserver + CSS keyframe animation
const revealObs = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('in');
      revealObs.unobserve(entry.target);
    }
  });
}, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });

document.querySelectorAll('[data-reveal]').forEach(el => revealObs.observe(el));

// Staggered musings rows
const firstRow = document.querySelector('[data-reveal-stagger]');
if (firstRow) {
  new IntersectionObserver((entries, obs) => {
    if (entries[0].isIntersecting) {
      [...document.querySelectorAll('[data-reveal-stagger]')].forEach((row, i) => {
        setTimeout(() => row.classList.add('in'), i * 48);
      });
      obs.disconnect();
    }
  }, { rootMargin: '0px 0px -5% 0px', threshold: 0.08 }).observe(firstRow);
}
</script>