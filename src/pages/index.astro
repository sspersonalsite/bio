<style is:global>
/* ════════════════════════════════════════════════════════
   Experience block animations — SVG + CSS, no JS
   ════════════════════════════════════════════════════════ */

.exp-block { position: relative; }

.exp-anim {
  position: absolute;
  right: 1.75rem;
  top: 50%;
  transform: translateY(-50%);
  width: 110px;
  height: 110px;
  pointer-events: none;
  opacity: 0.9;
  --accent: #00FFE0;
}
.exp-anim svg { width: 100%; height: 100%; display: block; }

/* Keep text clear of the animation widget on desktop */
.exp-block .exp-content { padding-right: 160px; }

/* Hide on narrow screens */
@media (max-width: 820px) {
  .exp-anim { display: none; }
  .exp-block .exp-content { padding-right: 0; }
}

/* Pause animations until the block has scrolled into view */
.exp-block:not(.in) .exp-anim * { animation-play-state: paused !important; }

/* ── 1. Matrix — data grid column-wave (AI Data & Research Ops) ── */
.exp-anim[data-anim="matrix"] .mdot {
  fill: var(--accent);
  opacity: 0.12;
  animation: mdot-flash 4s ease-in-out infinite;
}
@keyframes mdot-flash {
  0%, 100%   { opacity: 0.12; r: 2.2px; }
  35%, 58%   { opacity: 0.95; r: 3.2px; }
}

/* ── 2. Converge — 8 dots racing to center (Frontier AI) ── */
.exp-anim[data-anim="converge"] .cguid {
  stroke: var(--accent);
  stroke-width: 0.6;
  opacity: 0.18;
