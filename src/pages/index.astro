---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Scott Seidel" page="about">

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="hero" id="hero" aria-label="Introduction">
    <h1 class="hero-name" aria-label="Scott Seidel">
      <!-- "Scott" — white, letters stagger via animation-delay -->
      <span class="hero-line" aria-hidden="true">
        <span class="hero-name-letter" style="animation-delay:60ms">S</span>
        <span class="hero-name-letter" style="animation-delay:102ms">c</span>
        <span class="hero-name-letter" style="animation-delay:144ms">o</span>
        <span class="hero-name-letter" style="animation-delay:186ms">t</span>
        <span class="hero-name-letter" style="animation-delay:228ms">t</span>
      </span>
      <!-- "Seidel" — electric blue -->
      <span class="hero-line" aria-hidden="true">
        <span class="hero-name-letter" style="animation-delay:270ms;--letter-color:#037CFE">S</span>
        <span class="hero-name-letter" style="animation-delay:312ms;--letter-color:#037CFE">e</span>
        <span class="hero-name-letter" style="animation-delay:354ms;--letter-color:#037CFE">i</span>
        <span class="hero-name-letter" style="animation-delay:396ms;--letter-color:#037CFE">d</span>
        <span class="hero-name-letter" style="animation-delay:438ms;--letter-color:#037CFE">e</span>
        <span class="hero-name-letter" style="animation-delay:480ms;--letter-color:#037CFE">l</span>
      </span>
    </h1>

    <div class="hero-meta">
      <span class="hero-meta-line" style="animation-delay:700ms">Managing Director @ Soqono</span>
      <span class="hero-meta-line" style="animation-delay:800ms">Founder · PhD Engineer · Technical Research Operations</span>
    </div>

    <div class="hero-links" id="hero-links">
      <a href="https://www.soqono.com" target="_blank" rel="noopener" class="hero-link" style="--link-color:#94EC0E">Soqono</a>
      <a href="https://www.linkedin.com/in/scott-seidel" target="_blank" rel="noopener" class="hero-link" style="--link-color:#00FFE0">LinkedIn</a>
      <a href="https://scholar.google.com/citations?user=FVHVCKwAAAAJ&hl=en" target="_blank" rel="noopener" class="hero-link" style="--link-color:#FFF903">Scholar</a>
    </div>
  </section>

  <!-- Scroll indicator — centered mouse icon with cascading chevrons -->
  <div class="scroll-line" id="scroll-line" aria-hidden="true">
    <div class="scroll-inner">
      <div class="scroll-mouse">
        <div class="scroll-wheel"></div>
      </div>
      <div class="scroll-chevrons">
        <span></span>
        <span></span>
      </div>
    </div>
  </div>

  <div class="page-body">

    <!-- ── About card ──────────────────────────────────────── -->
    <div class="section-card" data-reveal>
      <div class="section-row" id="about" style="--section-color:#037CFE">
        <h2>About</h2>
      </div>
      <div class="bio-block">
        <p>
          I turn deep-tech research into products that ship at global scale.
          With a PhD in Chemical Engineering and 15 years of technical leadership,
          I've taken complex technologies from the lab to worldwide deployment across
          <strong>consumer electronics</strong>, <strong>autonomous vehicles</strong>,
          <strong>AR/VR</strong>, and <strong>frontier AI</strong>.
        </p>
        <p>
          As Founder and Managing Director of
          <a href="https://www.soqono.com" target="_blank" rel="noopener">Soqono</a>,
          I design and run custom AI training data collection and technical research
          operations programs for the world's leading tech companies, with delivery
          across 20+ countries. This work powers product development for
          next-generation technologies, providing the data and research infrastructure
          behind algorithm development at some of the most advanced engineering
          organizations in the world.
        </p>
      </div>
    </div>

    <!-- ── Experience card ─────────────────────────────────── -->
    <div class="section-card" data-reveal>
      <div class="section-row" id="experience" style="--section-color:#00FFE0">
        <h2>Experience</h2>
      </div>

      <div class="exp-block" data-reveal>
        <div class="exp-anim" data-anim="matrix" aria-hidden="true">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <!-- 4 columns × 5 rows — lights up left to right, top to bottom -->
            <!-- col 0 (x=40) -->
            <circle class="mdot" cx="40" cy="28"  r="2.2" style="animation-delay:0.00s"/>
            <circle class="mdot" cx="40" cy="63"  r="2.2" style="animation-delay:0.10s"/>
            <circle class="mdot" cx="40" cy="100" r="2.2" style="animation-delay:0.20s"/>
            <circle class="mdot" cx="40" cy="137" r="2.2" style="animation-delay:0.30s"/>
            <circle class="mdot" cx="40" cy="172" r="2.2" style="animation-delay:0.40s"/>
            <!-- col 1 (x=80) -->
            <circle class="mdot" cx="80" cy="28"  r="2.2" style="animation-delay:0.70s"/>
            <circle class="mdot" cx="80" cy="63"  r="2.2" style="animation-delay:0.80s"/>
            <circle class="mdot" cx="80" cy="100" r="2.2" style="animation-delay:0.90s"/>
            <circle class="mdot" cx="80" cy="137" r="2.2" style="animation-delay:1.00s"/>
            <circle class="mdot" cx="80" cy="172" r="2.2" style="animation-delay:1.10s"/>
            <!-- col 2 (x=120) -->
            <circle class="mdot" cx="120" cy="28"  r="2.2" style="animation-delay:1.40s"/>
            <circle class="mdot" cx="120" cy="63"  r="2.2" style="animation-delay:1.50s"/>
            <circle class="mdot" cx="120" cy="100" r="2.2" style="animation-delay:1.60s"/>
            <circle class="mdot" cx="120" cy="137" r="2.2" style="animation-delay:1.70s"/>
            <circle class="mdot" cx="120" cy="172" r="2.2" style="animation-delay:1.80s"/>
            <!-- col 3 (x=160) -->
            <circle class="mdot" cx="160" cy="28"  r="2.2" style="animation-delay:2.10s"/>
            <circle class="mdot" cx="160" cy="63"  r="2.2" style="animation-delay:2.20s"/>
            <circle class="mdot" cx="160" cy="100" r="2.2" style="animation-delay:2.30s"/>
            <circle class="mdot" cx="160" cy="137" r="2.2" style="animation-delay:2.40s"/>
            <circle class="mdot" cx="160" cy="172" r="2.2" style="animation-delay:2.50s"/>
          </svg>
        </div>
        <div class="exp-content">
          <div class="exp-top">
            <span class="exp-role">AI Data &amp; Research Operations</span>
          </div>
          <div class="exp-company">The common thread</div>
          <p class="exp-desc">For over a decade, through Soqono and global consulting programs before it, I've designed and run the custom data collection and research operations that state-of-the-art tech products are built on. Delivered across 20+ countries for the world's leading tech companies.</p>
        </div>
      </div>

      <div class="exp-block" data-reveal>
        <div class="exp-anim" data-anim="converge" aria-hidden="true">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <!-- Guide lines from each direction to center (faint) -->
            <line class="cguid" x1="100" y1="28"  x2="100" y2="100"/>
            <line class="cguid" x1="152" y1="48"  x2="100" y2="100"/>
            <line class="cguid" x1="172" y1="100" x2="100" y2="100"/>
            <line class="cguid" x1="152" y1="152" x2="100" y2="100"/>
            <line class="cguid" x1="100" y1="172" x2="100" y2="100"/>
            <line class="cguid" x1="48"  y1="152" x2="100" y2="100"/>
            <line class="cguid" x1="28"  y1="100" x2="100" y2="100"/>
            <line class="cguid" x1="48"  y1="48"  x2="100" y2="100"/>
            <!-- 8 dots converging toward center — custom translate via CSS vars -->
            <circle class="cdot" cx="100" cy="28"  r="3" style="--tx:0px;  --ty:72px;  animation-delay:0s"/>
            <circle class="cdot" cx="152" cy="48"  r="3" style="--tx:-52px;--ty:52px;  animation-delay:0.1s"/>
            <circle class="cdot" cx="172" cy="100" r="3" style="--tx:-72px;--ty:0px;   animation-delay:0.2s"/>
            <circle class="cdot" cx="152" cy="152" r="3" style="--tx:-52px;--ty:-52px; animation-delay:0.3s"/>
            <circle class="cdot" cx="100" cy="172" r="3" style="--tx:0px;  --ty:-72px; animation-delay:0.4s"/>
            <circle class="cdot" cx="48"  cy="152" r="3" style="--tx:52px; --ty:-52px; animation-delay:0.5s"/>
            <circle class="cdot" cx="28"  cy="100" r="3" style="--tx:72px; --ty:0px;   animation-delay:0.6s"/>
            <circle class="cdot" cx="48"  cy="48"  r="3" style="--tx:52px; --ty:52px;  animation-delay:0.7s"/>
